VITE_GITHUB_API_BASE_URL=https://api.github.com
VITE_GITHUB_API_VERSION=2022-11-28
# Optional for local development. Prefer a backend proxy for production because
# Vite environment variables are bundled into the client.
VITE_GITHUB_TOKEN=

# Optional. Set this to your Google Cloud chatbot backend endpoint
# (for example, a Cloud Run or Cloud Function URL that proxies to Vertex AI).
# The frontend sends the collected /setup data here as JSON.
VITE_CHAT_API_URL=
